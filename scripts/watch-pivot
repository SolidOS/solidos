#!/bin/bash

set -euo pipefail

unset PREFIX npm_config_prefix
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm

nvm use --delete-prefix

npx lerna bootstrap --force-local

declare -a packageNames=(
  "solid-ui"
  "contacts-pane"
  "profile-pane"
  "solid-panes"
  "mashlib"
  "pivot"
  )

startedPids=()
function cleanup {
  for pid in "${startedPids[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
}
trap cleanup INT TERM EXIT

for package in "${packageNames[@]}"; do
  case "$package" in
    "solid-ui")
      prestart="npm run build-version && npm run build-js && npm run postbuild-js"
      start="sh -c 'npm run watch:js & npm run watch:dist & wait'"
      ;;
    "contacts-pane")
      prestart="npm run build-dist"
      start="npm run watch-dist"
      ;;
    "profile-pane")
      prestart="npm run build-dist && npm run build-js"
      start='npx concurrently -k -n babel,webpack "npm:watch-js" "npm:watch-dist"'
      ;;
    "solid-panes")
      prestart="npm run build-version"
      start='npx concurrently -k -n babel,types,webpack "npm:watch-js" "npm:watch-types" "npm:watch-dist"'
      ;;
    "mashlib")
      prestart="npm run build-version"
      start="npm run watch"
      ;;
    "pivot")
      prestart=""
      start="npx community-solid-server -c ./config/dev-http-suffix.json config/customise-me.json -f ./data -p 3100 -b http://localhost:3100 -m ."
      ;;
    *)
      echo "Unknown package: $package"
      cleanup
      exit 1
      ;;
  esac

  echo "Preparing package $package..."
  (
    . "$NVM_DIR/nvm.sh"
    cd "workspaces/$package"
    nvm use --delete-prefix
    if [[ -n "$prestart" ]]; then
      eval "$prestart"
    fi
  )

  echo "Starting package $package..."
  (
    . "$NVM_DIR/nvm.sh"
    cd "workspaces/$package"
    nvm use --delete-prefix
    eval "$start"
  ) &
  pid=$!
  startedPids+=("$pid")

  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "Package $package failed to start. Stopping started watchers."
    cleanup
    exit 1
  fi
done

wait "${startedPids[@]}"
